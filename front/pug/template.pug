block head

doctype html
html(lang="en")
    head
        meta(charset='utf-8')
        title #{title}
        meta(content="width=device-width, initial-scale=1" name="viewport")
        link(rel="shortcut icon" href="img/favicon.ico" type="image/x-icon")
        link(rel='stylesheet', href='css/main.css')
        link(rel="preload" href="img/progress/progress-item.png" as="image")
        link(rel="preload" href="img/progress/progress-item-active.png" as="image")

    
        
    body
        style.
            picture, img {
                display: none;
            }
            img.place-icon {
                display: inline-block !important;
            }
        block content
        script(src='js/main.js')